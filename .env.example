# =============================================================================
# 内容生产流水线系统 — 环境变量模板
# =============================================================================
# 使用方式: cp .env.example .env  然后编辑 .env
# =============================================================================

# =============================================================================
# PostgreSQL 数据库
# =============================================================================
DB_PASSWORD=pipeline123

# =============================================================================
# MinIO 对象存储
# =============================================================================
MINIO_USER=pipeline
MINIO_PASSWORD=pipeline123

# =============================================================================
# RabbitMQ 消息队列
# =============================================================================
RABBITMQ_USER=pipeline
RABBITMQ_PASSWORD=pipeline123

# =============================================================================
# JWT 认证密钥（生产: openssl rand -hex 32）
# =============================================================================
JWT_SECRET=pipeline-secret-key-change-in-prod

# =============================================================================
# Python → Java 回调认证令牌（生产: openssl rand -hex 32）
# =============================================================================
CALLBACK_TOKEN=pipeline-callback-token-change-in-prod

# =============================================================================
# Python 回调 Java 基础 URL
# Docker: http://pipeline-admin:8080
# 本地:   http://host.docker.internal:8080
# =============================================================================
CALLBACK_BASE_URL=http://pipeline-admin:8080

# =============================================================================
# AI 模型 API Key（至少配一个）
# =============================================================================
PIPELINE_DEEPSEEK_API_KEY=
PIPELINE_OPENAI_API_KEY=
PIPELINE_ANTHROPIC_API_KEY=
PIPELINE_SENSENOVA_API_KEY=

# =============================================================================
# AES-256-GCM 加密密钥（生产: openssl rand -hex 16）
# =============================================================================
AES_ENCRYPTION_KEY=

# =============================================================================
# 其他
# =============================================================================
PIPELINE_DEBUG=false
SPRING_PROFILES_ACTIVE=dev
